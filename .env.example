# Google Calendar OAuth
USER_EMAIL=user@your-domain.com
GOOGLE_OAUTH_CLIENT_SECRETS=client_secrets.json
TOKEN_STORE_PATH=/data/tokens/user-token.fernet
TOKEN_PASSPHRASE=replace-with-a-long-random-passphrase
OAUTH_REDIRECT_PORT=8765

# Calendar watcher
CALENDAR_ID=primary
CALENDAR_LOOKAHEAD_MINUTES=60
CALENDAR_POLL_INTERVAL_SECONDS=300

# Runtime
LOG_LEVEL=INFO

# Persistent state
DB_PATH=/data/meeting-assistant.db
AUDIO_DIR=/data/audio
OUTPUT_DIR=/data/output
DEBUG_DIR=/data/debug

# Bot login
BOT_EMAIL=bot@your-domain.com
BOT_DISPLAY_NAME=Meeting Note-taker (bot)
STORAGE_STATE_PATH=/data/tokens/storage-state.fernet
STORAGE_PASSPHRASE=replace-with-a-long-random-passphrase
TEST_MEET_CODE=

# Gemini + Telegram
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
AUTO_PURGE_AUDIO=true
